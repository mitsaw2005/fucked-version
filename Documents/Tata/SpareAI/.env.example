# SpareAI — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# Add .env to your .gitignore file.

# ── Azure App Credentials ─────────────────────────────────
# Get these from Azure Portal → App Registrations → Your App
AZURE_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE
AZURE_CLIENT_SECRET=PASTE_YOUR_CLIENT_SECRET_HERE
AZURE_TENANT_ID=PASTE_YOUR_TENANT_ID_HERE

# ── OneDrive / SharePoint File Location ──────────────────
# Run: python onedrive_sync.py --find-file
# to get these IDs automatically after setting Azure credentials above.
ONEDRIVE_ITEM_ID=PASTE_YOUR_FILE_ITEM_ID_HERE

# Optional: if file is in a SharePoint document library
# (leave blank if personal OneDrive)
ONEDRIVE_DRIVE_ID=
SHAREPOINT_SITE_ID=

# ── Sync Settings ─────────────────────────────────────────
# How often (in minutes) to check OneDrive for changes
REFRESH_INTERVAL_MINUTES=5

# Whether to auto-retrain ML model when file changes
AUTO_RETRAIN=true
